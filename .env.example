COOLSENSE_API_KEY=change-me
COOLSENSE_ALLOW_EMPTY_API_KEY=false
COOLSENSE_POLL_INTERVAL_SECONDS=2
COOLSENSE_MODEL_PATH=coolsense_model.pt
COOLSENSE_HISTORY_SIZE=500
COOLSENSE_MODE=auto
COOLSENSE_READ_REQUIRES_AUTH=false
COOLSENSE_READ_RATE_LIMIT_PER_MINUTE=120
COOLSENSE_MUTATING_RATE_LIMIT_PER_MINUTE=30
COOLSENSE_METRICS_REQUIRES_AUTH=false
DATABASE_URL=postgresql+psycopg://coolsense:coolsense@postgres:5432/coolsense
