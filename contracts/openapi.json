          "timestamp",
          "coc",
          "cu_ppb",
          "zn_ppb",
          "chlorine_mgL",
          "turbidity_node4",
          "ph_node4",
          "compliant"
        ],
        "title": "HistoryPoint",
        "type": "object"
      },
      "ModelStatusResponse": {
        "properties": {
