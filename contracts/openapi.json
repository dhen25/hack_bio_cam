            "title": "Recommended Biocide Dose Mgl",
            "type": "number"
          },
          "recommended_blowdown_rate_m3_day": {
            "title": "Recommended Blowdown Rate M3 Day",
            "type": "number"
          },
          "recommended_coc_target": {
            "title": "Recommended Coc Target",
