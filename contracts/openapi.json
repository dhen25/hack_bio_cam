        "properties": {
          "horizon_hours": {
            "maximum": 24.0,
            "minimum": 1.0,
            "title": "Horizon Hours",
            "type": "integer"
          },
          "points": {
            "items": {
              "$ref": "#/components/schemas/ForecastPoint"
            },
            "title": "Points",
            "type": "array"
          }
        },
        "required": [
          "horizon_hours"
        ],
        "title": "ForecastResponse",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
