        "properties": {
          "compliant": {
            "title": "Compliant",
            "type": "boolean"
          },
          "predicted_chlorine_mgL": {
            "title": "Predicted Chlorine Mgl",
            "type": "number"
          },
          "predicted_cu_ppb": {
            "title": "Predicted Cu Ppb",
            "type": "number"
          },
          "predicted_turbidity_node4": {
            "title": "Predicted Turbidity Node4",
            "type": "number"
          },
          "predicted_zn_ppb": {
            "title": "Predicted Zn Ppb",
            "type": "number"
          },
          "timestamp": {
            "format": "date-time",
            "title": "Timestamp",
            "type": "string"
          }
        },
        "required": [
          "timestamp",
          "predicted_cu_ppb",
          "predicted_zn_ppb",
          "predicted_chlorine_mgL",
          "predicted_turbidity_node4",
