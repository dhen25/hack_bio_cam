{
  "components": {
    "schemas": {
      "BiocideBlock": {
        "properties": {
          "effective_hocl_mgL": {
            "default": 0.0,
            "title": "Effective Hocl Mgl",
            "type": "number"
          },
          "hocl_fraction_pct": {
            "default": 0.0,
            "title": "Hocl Fraction Pct",
            "type": "number"
          },
          "status": {
            "default": "unknown",
            "title": "Status",
            "type": "string"
          },
          "total_chlorine_mgL": {
            "default": 0.0,
            "title": "Total Chlorine Mgl",
            "type": "number"
          }
        },
        "title": "BiocideBlock",
        "type": "object"
      },
      "ControlOverrideRequest": {
        "properties": {
          "biocide_dose_mgL": {
            "anyOf": [
              {
                "exclusiveMinimum": 0.0,
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Biocide Dose Mgl"
          },
          "blowdown_rate_m3_day": {
            "anyOf": [
              {
                "exclusiveMinimum": 0.0,
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Blowdown Rate M3 Day"
          },
          "coc_target": {
            "anyOf": [
              {
                "maximum": 10.0,
                "minimum": 1.0,
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Coc Target"
          },
          "mode": {
            "$ref": "#/components/schemas/OverrideMode",
            "default": "manual"
          },
          "ph_setpoint": {
            "anyOf": [
              {
                "maximum": 9.5,
                "minimum": 6.5,
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Ph Setpoint"
          }
        },
        "title": "ControlOverrideRequest",
        "type": "object"
      },
      "CorrosionBlock": {
        "properties": {
          "cu_ppb": {
            "default": 0.0,
            "title": "Cu Ppb",
            "type": "number"
          },
          "severity_index": {
            "default": 0.0,
            "title": "Severity Index",
            "type": "number"
          },
          "source_diagnosis": {
            "default": "unknown",
            "title": "Source Diagnosis",
            "type": "string"
          },
          "zn_ppb": {
            "default": 0.0,
            "title": "Zn Ppb",
            "type": "number"
          }
        },
        "title": "CorrosionBlock",
        "type": "object"
      },
      "DischargeBlock": {
        "properties": {
          "mass_loadings_per_day": {
            "additionalProperties": {
              "type": "number"
            },
            "title": "Mass Loadings Per Day",
            "type": "object"
          },
          "predicted_next_1h": {
            "additionalProperties": {
              "type": "number"
            },
            "title": "Predicted Next 1H",
            "type": "object"
          }
        },
        "title": "DischargeBlock",
        "type": "object"
      },
      "EventInjectionRequest": {
        "properties": {
          "magnitude": {
            "default": 1.0,
            "exclusiveMinimum": 0.0,
            "title": "Magnitude",
            "type": "number"
          },
          "type": {
            "$ref": "#/components/schemas/EventType"
          }
        },
        "required": [
          "type"
        ],
        "title": "EventInjectionRequest",
        "type": "object"
      },
      "EventType": {
        "enum": [
          "corrosion_spike",
          "biocide_overdose",
          "biocide_underdose",
          "makeup_quality_drop",
          "concentration_buildup",
          "ph_drop",
          "turbidity_event"
        ],
        "title": "EventType",
        "type": "string"
      },
      "Exceedance": {
        "properties": {
          "limit": {
            "title": "Limit",
            "type": "number"
          },
          "measured": {
            "title": "Measured",
            "type": "number"
          },
          "parameter": {
            "title": "Parameter",
            "type": "string"
          },
          "severity": {
            "title": "Severity",
            "type": "number"
          }
        },
        "required": [
          "parameter",
          "measured",
          "limit",
          "severity"
        ],
        "title": "Exceedance",
        "type": "object"
      },
